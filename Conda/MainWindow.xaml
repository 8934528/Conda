<Window x:Class="Conda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Conda"
        mc:Ignorable="d"
        Title="Conda IDE" 
        Height="450" 
        Width="800" 
        Background="#1e1e1e"
        WindowStartupLocation="CenterScreen"
        MinHeight="400"
        MinWidth="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar with Logo -->
        <Border Grid.Row="0" Background="#2d2d30" Height="50">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <Image Source="Assets/logo/FirstIcon.png" Width="32" Height="32" Margin="0,0,10,0"/>
                <TextBlock Text="Conda IDE" FontSize="18" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
            <Button x:Name="NewProjectBtn"
                    Content="➕ New Project"
                    Click="OnNewProjectClicked"
                    Background="#007acc"
                    Foreground="White"
                    Width="220"
                    Height="45"
                    Margin="0,10"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold"/>

            <Button x:Name="OpenProjectBtn"
                    Content="📂 Open Project"
                    Click="OnOpenProjectClicked"
                    Background="#3c3c3c"
                    Foreground="White"
                    Width="220"
                    Height="45"
                    Margin="0,10"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
    
</Window>
