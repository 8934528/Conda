<Window x:Class="Conda.UI.Views.CustomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Conda.UI.Views"
        mc:Ignorable="d"
        Title="Note"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MinWidth="400"
        MaxWidth="600">

    <Window.Resources>
        <Storyboard x:Key="ShowDialogAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)"
                           From="0" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                           From="0.9" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                           From="0.9" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="HideDialogAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)"
                           From="1" To="0" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                           From="1" To="0.95" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                           From="1" To="0.95" Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>

    <Window.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1"/>
    </Window.RenderTransform>

    <Border Background="#2d2d30" 
            CornerRadius="8" 
            BorderBrush="#3c3c3c" 
            BorderThickness="1"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" 
                            Opacity="0.4" 
                            ShadowDepth="3"
                            Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Background="#252526" 
                    CornerRadius="8,8,0,0"
                    Padding="20,12">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TitleIcon" Text="ℹ️" FontSize="18" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TitleText" 
                                   Text="Dialog" 
                                   Foreground="White" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button x:Name="CloseButton"
                            HorizontalAlignment="Right"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="✕" Foreground="#cccccc" FontSize="14" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#c42b1c"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Background="#2d2d30" Padding="20">
                <StackPanel>
                    <TextBlock x:Name="MessageText" 
                               Text="Message" 
                               Foreground="#e0e0e0" 
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <StackPanel x:Name="CustomContent" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <Border Grid.Row="2" 
                    Background="#252526" 
                    CornerRadius="0,0,8,8"
                    Padding="15,12">
                <StackPanel x:Name="ButtonsPanel" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    <Button x:Name="Button1" 
                            Content="OK"
                            Width="80"
                            Height="30"
                            Margin="5,0,0,0"
                            Background="#007acc"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"
                            Click="Button_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" 
                                        Background="{TemplateBinding Background}" 
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#005a9e"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="Button2" 
                            Content="Cancel"
                            Width="80"
                            Height="30"
                            Margin="5,0,0,0"
                            Background="#3c3c3c"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"
                            Visibility="Collapsed"
                            Click="Button_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" 
                                        Background="{TemplateBinding Background}" 
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#4c4c4c"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
    