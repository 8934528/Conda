<Window x:Class="Conda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:Conda.UI.Views"
        mc:Ignorable="d"
        d:DesignHeight="900" d:DesignWidth="1400"
        Background="#1e1e1e"
        Icon="/Assets/AppIcon.png"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="50" 
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        
        <Style x:Key="CommonRoundedButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Control -->
        <local:TitleBarControl Grid.Row="0" 
                               NewProjectClicked="OnNewProjectClicked"
                               OpenProjectClicked="OnOpenProjectClicked"
                               ExitClicked="OnExitClicked"
                               PreferencesClicked="OnPreferencesClicked"
                               SettingsClicked="OnSettingsClicked"
                               ToggleFullScreenClicked="OnToggleFullScreenClicked"
                               ResetLayoutClicked="OnResetLayoutClicked"
                               RecentProjectsClicked="OnRecentProjectsClicked"
                               ProjectSettingsClicked="OnProjectSettingsClicked"
                               BuildClicked="OnBuildClicked"
                               ExportClicked="OnExportClicked"
                               PackageManagerClicked="OnPackageManagerClicked"
                               ExtensionsClicked="OnExtensionsClicked"
                               OpenTerminalClicked="OnOpenTerminalClicked"
                               RunCommandClicked="OnRunCommandClicked"
                               DocumentationClicked="OnDocumentationClicked"
                               AboutClicked="OnAboutClicked"
                               SettingsIconClicked="OnSettingsIconClicked"/>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                
                <!-- Welcome Section -->
                <TextBlock Text="Project Dashboard" 
                           FontSize="12" 
                           Foreground="White" 
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Manage your Conda game projects from one place." 
                           FontSize="12" 
                           Foreground="#aaaaaa"
                           Margin="0,0,0,30"/>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" 
                           FontSize="12" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>

                <WrapPanel>
                    <Button Click="OnNewProjectClicked"
                            Background="#007acc"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="New Project"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="OnOpenProjectClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Open Project"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="OnInstallDepsClicked"
                            Background="#2d5a2d"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PackageDown" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Install Dep..."/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="OnCheckPythonClicked"
                            Background="#6a1b9a"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="LanguagePython" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Check Python"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <!-- Recent Projects -->
                <TextBlock Text="Recent Projects" 
                           FontSize="12" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,20,0,15"/>

                <Border Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1"
                        CornerRadius="3"
                        Height="120">
                    <ListBox x:Name="RecentProjectsList"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="12"
                             SelectionChanged="OnProjectSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10,8">
                                <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14" Margin="0,0,10,0" Foreground="#888888"/>
                                <TextBlock Text="{Binding Name}" Foreground="White" Width="120"/>
                                <TextBlock Text="{Binding Path}" Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Click="OnOpenSelectedProject"
                            Background="#007acc"
                            Foreground="White"
                            Width="110"
                            Height="30"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Open Selected"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnRefreshClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="110"
                            Height="30"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="System Status" 
                                   FontSize="12" 
                                   Foreground="White" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Python:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="PythonStatusText" Grid.Row="0" Grid.Column="1" Text="Checking..." Foreground="White"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Projects Path:" Foreground="#aaaaaa"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectsPath}" Foreground="White"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Projects:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="ProjectCountText" Grid.Row="2" Grid.Column="1" Text="0" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Tips Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10">
                            <Run Text="Tips"/>
                        </TextBlock>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Information" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Use the file explorer to manage your project files" Foreground="#aaaaaa"/>
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Keyboard" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Press F5 to run your game" Foreground="#aaaaaa"/>
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PackageVariant" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Install pygame using: pip install pygame" Foreground="#aaaaaa"/>
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="HexagonOutline" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Create a virtual environment for dependency isolation" Foreground="#aaaaaa"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Notification -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="3" Padding="20,12" BorderBrush="#007acc" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial x:Name="ToastIcon" Kind="CheckCircle" Width="14" Height="14" Foreground="#4ec9b0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Project created successfully!" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Window>
