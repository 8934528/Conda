<Window x:Class="Conda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
       d:DesignHeight="900" d:DesignWidth="1400"
        Title="Conda IDE"
        Background="#1e1e1e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Navs & Tabs -->
        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="/Assets/logo/FirstIcon.png" Width="28" Height="28" Margin="0,0,10,0"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="150,0,0,0">
                    <!-- File -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0">
                        <MenuItem Header="File" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="New Project" Click="OnNewProjectClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Open Project" Click="OnOpenProjectClicked" Style="{StaticResource MenuItemStyle}"/>
                            <Separator Background="#3c3c3c"/>
                            <MenuItem Header="Exit" Click="OnExitClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                    
                    <!-- Edit -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Edit" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Preferences" Click="OnPreferencesClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Settings" Click="OnSettingsClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                    
                    <!-- View -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="View" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Toggle Full Screen" Click="OnToggleFullScreenClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Reset Layout" Click="OnResetLayoutClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                    
                    <!-- Project -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Project" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Recent Projects" Click="OnRecentProjectsClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Project Settings" Click="OnProjectSettingsClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                    
                    <!-- Build -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Build" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Build Project" Click="OnBuildClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Export Game" Click="OnExportClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                    
                    <!-- Tools -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Tools" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Package Manager" Click="OnPackageManagerClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Extensions" Click="OnExtensionsClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                    
                    <!-- Terminal -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Terminal" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Open Terminal" Click="OnOpenTerminalClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Run Command" Click="OnRunCommandClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- Help -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Help" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Documentation" Click="OnDocumentationClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="About" Click="OnAboutClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>
                
                <!-- Settings -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="OnSettingsIconClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="18" Foreground="#cccccc"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                
                <!-- Welcome Section -->
                <TextBlock Text="Project Dashboard" 
                           FontSize="24" 
                           Foreground="White" 
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Manage your Conda game projects from one place." 
                           FontSize="14" 
                           Foreground="#aaaaaa"
                           Margin="0,0,0,30"/>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" 
                           FontSize="16" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>

                <WrapPanel>
                    <Button Content="➕ Create New Project" 
                            Click="OnNewProjectClicked"
                            Background="#007acc"
                            Foreground="White"
                            Width="180"
                            Height="40"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                    
                    <Button Content="📂 Open Existing Project" 
                            Click="OnOpenProjectClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="180"
                            Height="40"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                    
                    <Button Content="📦 Install Dependencies" 
                            Click="OnInstallDepsClicked"
                            Background="#2d5a2d"
                            Foreground="White"
                            Width="180"
                            Height="40"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                    
                    <Button Content="🐍 Check Python" 
                            Click="OnCheckPythonClicked"
                            Background="#6a1b9a"
                            Foreground="White"
                            Width="180"
                            Height="40"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                </WrapPanel>

                <!-- Recent Projects -->
                <TextBlock Text="Recent Projects" 
                           FontSize="16" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,20,0,15"/>

                <Border Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1"
                        CornerRadius="6"
                        Height="200">
                    <ListBox x:Name="RecentProjectsList"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="13"
                             SelectionChanged="OnProjectSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10,8">
                                <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Name}" Foreground="White" Width="200"/>
                                <TextBlock Text="{Binding Path}" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Open Selected" 
                            Click="OnOpenSelectedProject"
                            Background="#007acc"
                            Foreground="White"
                            Width="120"
                            Height="32"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12"/>
                    <Button Content="Refresh" 
                            Click="OnRefreshClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="120"
                            Height="32"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12"/>
                </StackPanel>

                <!-- Status Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="System Status" 
                                   FontSize="14" 
                                   Foreground="White" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Python:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="PythonStatusText" Grid.Row="0" Grid.Column="1" Text="Checking..." Foreground="White"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Projects Path:" Foreground="#aaaaaa"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectsPath}" Foreground="White"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Projects:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="ProjectCountText" Grid.Row="2" Grid.Column="1" Text="0" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Tips Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="💡 Tips" 
                                   FontSize="14" 
                                   Foreground="White" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="• Use the file explorer to manage your project files" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                        <TextBlock Text="• Press F5 to run your game" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                        <TextBlock Text="• Install pygame using: pip install pygame" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                        <TextBlock Text="• Create a virtual environment for dependency isolation" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Toast Notification Overlay -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="8" Padding="20,12" BorderBrush="#007acc" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastIcon" Text="✅" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Project created successfully!" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Window>
