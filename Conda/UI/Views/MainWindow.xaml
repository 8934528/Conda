<Window x:Class="Conda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        d:DesignHeight="900" d:DesignWidth="1400"
        Background="#1e1e1e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        
        <Style x:Key="CommonRoundedButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Navs & Tabs -->
        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#cccccc"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Margin="2,0">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                                <Border x:Name="SubmenuBorder" 
                                        Background="#252526" 
                                        BorderBrush="#3c3c3c" 
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,2,0,0"
                                        Padding="4">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="15" 
                                                          Opacity="0.3" 
                                                          ShadowDepth="2"
                                                          Color="Black"/>
                                                    </Border.Effect>
                                                    <StackPanel IsItemsHost="True" 
                                                KeyboardNavigation.DirectionalNavigation="Cycle"
                                                Margin="0,4"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSubmenuOpen" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSubMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#e0e0e0"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="3"
                            Margin="2">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2d2d30"/>
                                            <Setter Property="Foreground" Value="#007acc"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSeparatorStyle" TargetType="Separator">
                        <Setter Property="Background" Value="#3c3c3c"/>
                        <Setter Property="Height" Value="1"/>
                        <Setter Property="Margin" Value="8,4,8,4"/>
                    </Style>
                </Grid.Resources>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="/Assets/logo/FirstIcon.png" Width="28" Height="28" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="450,0,0,0">
                    <Menu Background="Transparent" BorderThickness="0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FileOutline" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="File"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+N">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="New Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+O">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+S">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentSaveAll" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Save All"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="History" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Recent Projects"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnExitClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Alt+F4">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Exit"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Edit"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+X">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentCut" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Cut"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+C">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Copy"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+V">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentPaste" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Paste"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnPreferencesClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+,">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Tune" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Preferences"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+,">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Settings"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Eye" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="View"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnToggleFullScreenClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F11">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Fullscreen" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Toggle Full Screen"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnResetLayoutClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Reset Layout"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+1">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Show Dashboard"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+2">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CodeBraces" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Show Editor"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+`">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Show Terminal"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Project"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="New Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="History" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Recent Projects"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnProjectSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Project Settings"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PackageVariant" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Project Dependencies"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="HammerWrench" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Build"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnBuildClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F7">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Hammer" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Build Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F5">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Run Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F6">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Bug" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Debug Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnExportClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Export" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Export Game"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CogOutline" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Build Settings"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Wrench" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Tools"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnPackageManagerClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PackageVariantClosed" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Package Manager"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnExtensionsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Puzzle" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Extensions"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="LanguagePython" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Python Environment"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Code Analysis"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Terminal"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnOpenTerminalClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+`">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Terminal"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnRunCommandClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+P">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Run" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Run Command"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+L">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Eraser" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Clear Terminal"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+T">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PlusBox" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="New Terminal Tab"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="HelpCircle" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Help"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnDocumentationClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F1">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="BookOpenPageVariant" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Documentation"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Lightbulb" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Tips and Tricks"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Bug" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Report Issue"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnAboutClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Information" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="About"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- Settings Button -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,0">
                    <Button x:Name="SettingsButton"
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand"
                                Click="OnSettingsIconClicked"
                                Width="100"
                                Height="32"
                                Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Foreground="#cccccc" Margin="0,0,8,0"/>
                            <TextBlock Text="Settings" FontSize="12" Foreground="#cccccc"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                
                <!-- Welcome Section -->
                <TextBlock Text="Project Dashboard" 
                           FontSize="12" 
                           Foreground="White" 
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Manage your Conda game projects from one place." 
                           FontSize="12" 
                           Foreground="#aaaaaa"
                           Margin="0,0,0,30"/>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" 
                           FontSize="12" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>

                <WrapPanel>
                    <Button Click="OnNewProjectClicked"
                            Background="#007acc"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="New Project"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="OnOpenProjectClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Open Project"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="OnInstallDepsClicked"
                            Background="#2d5a2d"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PackageDown" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Install Dep..."/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="OnCheckPythonClicked"
                            Background="#6a1b9a"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="LanguagePython" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Check Python"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <!-- Recent Projects -->
                <TextBlock Text="Recent Projects" 
                           FontSize="12" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,20,0,15"/>

                <Border Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1"
                        CornerRadius="3"
                        Height="120">
                    <ListBox x:Name="RecentProjectsList"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="12"
                             SelectionChanged="OnProjectSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10,8">
                                <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14" Margin="0,0,10,0" Foreground="#888888"/>
                                <TextBlock Text="{Binding Name}" Foreground="White" Width="120"/>
                                <TextBlock Text="{Binding Path}" Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Click="OnOpenSelectedProject"
                            Background="#007acc"
                            Foreground="White"
                            Width="110"
                            Height="30"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Open Selected"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnRefreshClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="110"
                            Height="30"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="System Status" 
                                   FontSize="12" 
                                   Foreground="White" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Python:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="PythonStatusText" Grid.Row="0" Grid.Column="1" Text="Checking..." Foreground="White"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Projects Path:" Foreground="#aaaaaa"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectsPath}" Foreground="White"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Projects:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="ProjectCountText" Grid.Row="2" Grid.Column="1" Text="0" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Tips Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10">
                            <Run Text="Tips"/>
                        </TextBlock>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Information" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Use the file explorer to manage your project files" Foreground="#aaaaaa"/>
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Keyboard" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Press F5 to run your game" Foreground="#aaaaaa"/>
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PackageVariant" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Install pygame using: pip install pygame" Foreground="#aaaaaa"/>
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="HexagonOutline" Width="14" Height="14" Foreground="#aaaaaa" Margin="0,0,8,0"/>
                            <TextBlock Text="Create a virtual environment for dependency isolation" Foreground="#aaaaaa"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Notification -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="3" Padding="20,12" BorderBrush="#007acc" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial x:Name="ToastIcon" Kind="CheckCircle" Width="14" Height="14" Foreground="#4ec9b0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Project created successfully!" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Window>
