<Window x:Class="Conda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="900" d:DesignWidth="1400"
        Background="#1e1e1e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        
        <Style x:Key="CommonRoundedButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Navs & Tabs -->
        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#cccccc"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Margin="2,0">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                                <Border x:Name="SubmenuBorder" 
                                        Background="#252526" 
                                        BorderBrush="#3c3c3c" 
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,2,0,0"
                                        Padding="4">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="15" 
                                                          Opacity="0.3" 
                                                          ShadowDepth="2"
                                                          Color="Black"/>
                                                    </Border.Effect>
                                                    <StackPanel IsItemsHost="True" 
                                                KeyboardNavigation.DirectionalNavigation="Cycle"
                                                Margin="0,4"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSubmenuOpen" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSubMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#e0e0e0"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="3"
                            Margin="2">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2d2d30"/>
                                            <Setter Property="Foreground" Value="#007acc"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSeparatorStyle" TargetType="Separator">
                        <Setter Property="Background" Value="#3c3c3c"/>
                        <Setter Property="Height" Value="1"/>
                        <Setter Property="Margin" Value="8,4,8,4"/>
                    </Style>
                </Grid.Resources>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="/Assets/logo/FirstIcon.png" Width="28" Height="28" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="450,0,0,0">
                    <Menu Background="Transparent" BorderThickness="0">
                        <MenuItem Header="📄 File" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="📁 New Project" Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+N"/>
                            <MenuItem Header="📂 Open Project" Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+O"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="💾 Save All" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+S"/>
                            <MenuItem Header="🔄 Recent Projects" Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="❌ Exit" Click="OnExitClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Alt+F4"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="✏️ Edit" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="✂️ Cut" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+X"/>
                            <MenuItem Header="📋 Copy" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+C"/>
                            <MenuItem Header="📌 Paste" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+V"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="⚙️ Preferences" Click="OnPreferencesClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+,"/>
                            <MenuItem Header="🔧 Settings" Click="OnSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+,"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="👁️ View" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🖥️ Toggle Full Screen" Click="OnToggleFullScreenClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F11"/>
                            <MenuItem Header="🔄 Reset Layout" Click="OnResetLayoutClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="📊 Show Dashboard" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+1"/>
                            <MenuItem Header="📝 Show Editor" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+2"/>
                            <MenuItem Header="📟 Show Terminal" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+`"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="📁 Project" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🆕 New Project" Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="📂 Open Project" Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🕒 Recent Projects" Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="⚙️ Project Settings" Click="OnProjectSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="📦 Project Dependencies" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="🔧 Build" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🔨 Build Project" Click="OnBuildClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F7"/>
                            <MenuItem Header="▶️ Run Project" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F5"/>
                            <MenuItem Header="🐛 Debug Project" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F6"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="📦 Export Game" Click="OnExportClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="📋 Build Settings" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="🛠️ Tools" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="📦 Package Manager" Click="OnPackageManagerClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🧩 Extensions" Click="OnExtensionsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="🐍 Python Environment" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🔍 Code Analysis" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header=">_ Terminal" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🖥️ Open Terminal" Click="OnOpenTerminalClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+`"/>
                            <MenuItem Header="⚡ Run Command" Click="OnRunCommandClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+P"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="🧹 Clear Terminal" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+L"/>
                            <MenuItem Header="📋 New Terminal Tab" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+T"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="❓ Help" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="📚 Documentation" Click="OnDocumentationClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F1"/>
                            <MenuItem Header="💡 Tips and Tricks" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🐛 Report Issue" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="ℹ️ About" Click="OnAboutClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- Settings Button with animation -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,0">
                    <Button x:Name="SettingsButton"
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand"
                                Click="OnSettingsIconClicked"
                                Width="100"
                                Height="32"
                                Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="⚙️ Settings" FontSize="12" Foreground="#cccccc"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                
                <!-- Welcome Section -->
                <TextBlock Text="Project Dashboard" 
                           FontSize="24" 
                           Foreground="White" 
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Manage your Conda game projects from one place." 
                           FontSize="14" 
                           Foreground="#aaaaaa"
                           Margin="0,0,0,30"/>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" 
                           FontSize="16" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>

                <WrapPanel>
                    <Button Content="➕ New Project" 
                            Click="OnNewProjectClicked"
                            Background="#007acc"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                    
                    <Button Content="📂 Open Project" 
                            Click="OnOpenProjectClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                    
                    <Button Content="📦 Install Dep..." 
                            Click="OnInstallDepsClicked"
                            Background="#2d5a2d"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                    
                    <Button Content="🐍 Check Python" 
                            Click="OnCheckPythonClicked"
                            Background="#6a1b9a"
                            Foreground="White"
                            Width="110"
                            Height="35"
                            Margin="0,0,10,10"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="13"/>
                </WrapPanel>

                <!-- Recent Projects -->
                <TextBlock Text="Recent Projects" 
                           FontSize="16" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Margin="0,20,0,15"/>

                <Border Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1"
                        CornerRadius="3"
                        Height="120">
                    <ListBox x:Name="RecentProjectsList"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="13"
                             SelectionChanged="OnProjectSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10,8">
                                <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Name}" Foreground="White" Width="120"/>
                                <TextBlock Text="{Binding Path}" Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Open Selected" 
                            Click="OnOpenSelectedProject"
                            Background="#007acc"
                            Foreground="White"
                            Width="90"
                            Height="30"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12"/>
                    <Button Content="Refresh" 
                            Click="OnRefreshClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            Width="90"
                            Height="30"
                            Margin="5"
                            Style="{StaticResource CommonRoundedButtonStyle}"
                            FontSize="12"/>
                </StackPanel>

                <!-- Status Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="System Status" 
                                   FontSize="14" 
                                   Foreground="White" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Python:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="PythonStatusText" Grid.Row="0" Grid.Column="1" Text="Checking..." Foreground="White"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Projects Path:" Foreground="#aaaaaa"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProjectsPath}" Foreground="White"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Projects:" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="ProjectCountText" Grid.Row="2" Grid.Column="1" Text="0" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Tips Section -->
                <Border Style="{StaticResource DashboardCardStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="💡 Tips" 
                                   FontSize="14" 
                                   Foreground="White" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="• Use the file explorer to manage your project files" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                        <TextBlock Text="• Press F5 to run your game" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                        <TextBlock Text="• Install pygame using: pip install pygame" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                        <TextBlock Text="• Create a virtual environment for dependency isolation" 
                                   Foreground="#aaaaaa" Margin="0,2"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Notification -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="3" Padding="20,12" BorderBrush="#007acc" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastIcon" Text="✅" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Project created successfully!" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Window>
