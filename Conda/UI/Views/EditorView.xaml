<Page x:Class="Conda.UI.Views.EditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Conda.Editor"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1400"
      Title="Conda Editor"
      Background="#1e1e1e"
      Loaded="Page_Loaded">

    <Page.Resources>
        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Header="📝 Open" Click="OnOpenFileClick"/>
            <Separator/>
            <MenuItem Header="📄 New File" Click="OnNewFileClick"/>
            <MenuItem Header="📁 New Folder" Click="OnNewFolderClick"/>
            <Separator/>
            <MenuItem Header="✏️ Rename" Click="OnRenameClick"/>
            <MenuItem Header="🗑️ Delete" Click="OnDeleteClick"/>
            <Separator/>
            <MenuItem Header="📋 Copy Path" Click="OnCopyPathClick"/>
            <MenuItem Header="🔄 Reveal in Explorer" Click="OnRevealInExplorerClick"/>
        </ContextMenu>
        
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10,10,10,5"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Navs & Tabs -->
        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="../../Assets/logo/FirstIcon.png" Width="28" Height="28" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="150,0,0,0">
                    <!-- File -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0">
                        <MenuItem Header="File" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="New Project" Click="OnNewProjectClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Open Project" Click="OnOpenProjectClicked" Style="{StaticResource MenuItemStyle}"/>
                            <Separator Background="#3c3c3c"/>
                            <MenuItem Header="Exit" Click="OnExitClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- Edit -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Edit" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Preferences" Click="OnPreferencesClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Settings" Click="OnSettingsClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- View -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="View" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Toggle Full Screen" Click="OnToggleFullScreenClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Reset Layout" Click="OnResetLayoutClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- Project -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Project" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Recent Projects" Click="OnRecentProjectsClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Project Settings" Click="OnProjectSettingsClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- Build -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Build" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Build Project" Click="OnBuildClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Export Game" Click="OnExportClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- Tools -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Tools" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Package Manager" Click="OnPackageManagerClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Extensions" Click="OnExtensionsClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- Terminal -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Terminal" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Open Terminal" Click="OnOpenTerminalClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="Run Command" Click="OnRunCommandClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <!-- Help -->
                    <Menu Background="Transparent" Foreground="#cccccc" BorderThickness="0" Margin="10,0,0,0">
                        <MenuItem Header="Help" Background="Transparent" Foreground="#cccccc">
                            <MenuItem Header="Documentation" Click="OnDocumentationClicked" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Header="About" Click="OnAboutClicked" Style="{StaticResource MenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- Settings -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="OnSettingsIconClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" FontSize="18" Foreground="#cccccc"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/> <!-- Sidebar -->
                <ColumnDefinition Width="*"/>  <!-- Editor Area -->
                <ColumnDefinition Width="280"/> <!-- Explorer -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="#333333" BorderBrush="#3c3c3c" BorderThickness="0,0,1,0">
                <StackPanel>
                    <Button x:Name="CodeEditorToggle" ToolTip="Code Editor" Click="OnShowCodeEditor" Height="50" Background="#1e1e1e" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="💻" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="SceneEditorToggle" ToolTip="Scene Editor" Click="OnShowSceneEditor" Height="50" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="🎨" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- EDITOR AREA -->
            <Grid Grid.Row="0" Grid.Column="1">
                <!-- CODE EDITOR (Monaco) -->
                <Border x:Name="CodeEditorContainer" Background="#1e1e1e" Visibility="Visible">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Editor Label -->
                        <TextBlock Grid.Row="0" Text="📝 EDITOR" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Tab Control -->
                        <TabControl x:Name="FileTabs"
                                    Grid.Row="1"
                                    Background="#2d2d30"
                                    BorderThickness="0"
                                    SelectionChanged="OnTabSelectionChanged">
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="5,0,5,0" FontSize="12"/>
                                        <TextBlock Text="{Binding Name}" Margin="0,0,5,0"/>
                                        <Button Content="✕" 
                                                Width="16" 
                                                Height="16" 
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#888"
                                                Cursor="Hand"
                                                Click="OnCloseTabClick"
                                                Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>

                        <!-- Monaco Editor -->
                        <Border Grid.Row="2" Background="#1e1e1e">
                            <wv2:WebView2 x:Name="CodeWebView"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- SCENE EDITOR -->
                <Grid x:Name="SceneEditorContainer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Toolbar -->
                        <RowDefinition Height="*"/>    <!-- Canvas + Hierarchy -->
                    </Grid.RowDefinitions>

                    <!-- SCENE TOOLBAR -->
                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Save Scene" Click="OnSaveScene" Margin="5" Background="#3c3c3c" Foreground="White" BorderThickness="0" Padding="8,4"/>
                            <Button Content="📂 Load Scene" Click="OnLoadScene" Margin="5" Background="#3c3c3c" Foreground="White" BorderThickness="0" Padding="8,4"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- SCENE CANVAS -->
                        <Canvas x:Name="SceneCanvas"
                                Background="#1e1e1e"
                                AllowDrop="True"
                                Drop="OnSceneDrop"
                                Grid.Column="0"
                                ClipToBounds="True"/>

                        <!-- HIERARCHY PANEL -->
                        <Border Grid.Column="1" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1,0,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Hierarchy" Foreground="White" Margin="10" FontWeight="Bold"/>
                                <ListBox x:Name="SceneHierarchy"
                                         Background="#1e1e1e"
                                         Foreground="White"
                                         BorderThickness="0"
                                         DisplayMemberPath="Name"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- RIGHT PANEL (Explorer) -->
            <Grid Grid.Row="0" Grid.Column="2" Grid.RowSpan="2">
                <!-- FILE EXPLORER -->
                <Border x:Name="ExplorerContainer" 
                        Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1,0,0,0"
                        Visibility="Visible">
                    <DockPanel>
                        <!-- Explorer Header -->
                        <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                            <TextBlock Text="📁 EXPLORER"
                                       Foreground="#aaaaaa"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="10,10,10,10"/>
                        </Border>
                        
                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top" Background="#252526" Padding="5">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="📄 New File" 
                                        Click="OnNewFileToolbarClick"
                                        Background="#3c3c3c"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="8,5"
                                        Margin="0,0,5,0"
                                        FontSize="11"
                                        Cursor="Hand"/>
                                <Button Content="📁 New Folder" 
                                        Click="OnNewFolderToolbarClick"
                                        Background="#3c3c3c"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="8,5"
                                        FontSize="11"
                                        Cursor="Hand"/>
                                <Button Content="🔄 Refresh" 
                                        Click="OnRefreshClicked"
                                        Background="#3c3c3c"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="8,5"
                                        Margin="5,0,0,0"
                                        FontSize="11"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Border>

                        <!-- File Tree -->
                        <TreeView x:Name="FileTree"
                                  Background="#252526"
                                  Foreground="White"
                                  BorderThickness="0"
                                  FontSize="13"
                                  AllowDrop="True"
                                  DragEnter="OnTreeViewDragEnter"
                                  Drop="OnTreeViewDrop"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewRightClick">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:FileNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Tag="{Binding}">
                                        <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- INSPECTOR PANEL -->
                <Border x:Name="InspectorContainer" 
                        Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1,0,0,0"
                        Visibility="Collapsed">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                            <TextBlock Text="🔍 INSPECTOR"
                                       Foreground="#aaaaaa"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="10,10,10,10"/>
                        </Border>

                        <ScrollViewer>
                            <StackPanel Margin="10">
                                <TextBlock Text="Name" Foreground="#888" Margin="0,5"/>
                                <TextBox x:Name="NameBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5"/>

                                <TextBlock Text="Position X" Foreground="#888" Margin="0,10,0,5"/>
                                <TextBox x:Name="PosXBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5"/>

                                <TextBlock Text="Position Y" Foreground="#888" Margin="0,10,0,5"/>
                                <TextBox x:Name="PosYBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5"/>

                                <TextBlock Text="Width" Foreground="#888" Margin="0,10,0,5"/>
                                <TextBox x:Name="WidthBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5"/>

                                <TextBlock Text="Height" Foreground="#888" Margin="0,10,0,5"/>
                                <TextBox x:Name="HeightBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5"/>

                                <TextBlock Text="Rotation" Foreground="#888" Margin="0,10,0,5"/>
                                <TextBox x:Name="RotationBox" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5"/>

                                <Button Content="Apply Changes"
                                        Click="OnApplyInspector"
                                        Margin="0,20,0,0"
                                        Background="#007acc"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="10,8"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- OUTPUT CONSOLE -->
            <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                    Background="#1e1e1e"
                    BorderBrush="#3c3c3c"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Console Header -->
                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="📟 OUTPUT"
                                       Foreground="#aaaaaa"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="10,8,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                                <Button Content="Clear" 
                                        Click="OnClearConsoleClicked"
                                        Background="Transparent"
                                        Foreground="#aaaaaa"
                                        BorderThickness="0"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Margin="5,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBox x:Name="OutputConsole"
                             Grid.Row="1"
                             Background="#1e1e1e"
                             Foreground="#4ec9b0"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Margin="10,5,10,10"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Toast Notification Overlay -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="8" Padding="20,12" BorderBrush="#007acc" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastIcon" Text="✅" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Action completed successfully!" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Page>
