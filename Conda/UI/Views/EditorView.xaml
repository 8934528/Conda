<Page x:Class="Conda.UI.Views.EditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:local="clr-namespace:Conda.Editor"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1400"
      Background="#1e1e1e"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="50" To="0" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Header="Open" Click="OnOpenFileClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="New File" Click="OnNewFileClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FilePlus" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="New Folder" Click="OnNewFolderClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Rename" Click="OnRenameClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Delete" Click="OnDeleteClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Copy Path" Click="OnCopyPathClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Reveal in Explorer" Click="OnRevealInExplorerClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10,10,10,5"/>
        </Style>

        <Style x:Key="SceneToolButton" TargetType="Button">
            <Setter Property="Background" Value="#3c3c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4c4c4c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Border">
            <Setter Property="Margin" Value="10,2,10,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3e3e42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Navs & Tabs -->
        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#cccccc"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Margin="2,0">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                                <Border x:Name="SubmenuBorder" 
                                        Background="#252526" 
                                        BorderBrush="#3c3c3c" 
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,2,0,0"
                                        Padding="4">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="15" 
                                                          Opacity="0.3" 
                                                          ShadowDepth="2"
                                                          Color="Black"/>
                                                    </Border.Effect>
                                                    <StackPanel IsItemsHost="True" 
                                                KeyboardNavigation.DirectionalNavigation="Cycle"
                                                Margin="0,4"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSubmenuOpen" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSubMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#e0e0e0"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="3"
                            Margin="2">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2d2d30"/>
                                            <Setter Property="Foreground" Value="#007acc"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSeparatorStyle" TargetType="Separator">
                        <Setter Property="Background" Value="#3c3c3c"/>
                        <Setter Property="Height" Value="1"/>
                        <Setter Property="Margin" Value="8,4,8,4"/>
                    </Style>
                </Grid.Resources>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="/Assets/logo/FirstIcon.png" Width="28" Height="28" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="450,0,0,0">
                    <Menu Background="Transparent" BorderThickness="0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FileOutline" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="File"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+N">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="New Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+O">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+S">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentSaveAll" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Save All"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="History" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Recent Projects"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnExitClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Alt+F4">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Exit"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Edit"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+X">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentCut" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Cut"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+C">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Copy"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+V">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentPaste" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Paste"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnPreferencesClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+,">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Tune" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Preferences"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+,">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Settings"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Eye" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="View"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnToggleFullScreenClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F11">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Fullscreen" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Toggle Full Screen"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnResetLayoutClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Reset Layout"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+1">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Show Dashboard"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+2">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CodeBraces" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Show Editor"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+`">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Show Terminal"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Folder" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Project"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="New Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="History" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Recent Projects"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnProjectSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Project Settings"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PackageVariant" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Project Dependencies"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="HammerWrench" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Build"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnBuildClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F7">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Hammer" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Build Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F5">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Run Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F6">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Bug" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Debug Project"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnExportClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Export" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Export Game"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CogOutline" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Build Settings"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Wrench" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Tools"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnPackageManagerClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PackageVariantClosed" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Package Manager"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnExtensionsClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Puzzle" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Extensions"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="LanguagePython" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Python Environment"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Code Analysis"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Terminal"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnOpenTerminalClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+`">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Console" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Terminal"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="OnRunCommandClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+P">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Run" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Run Command"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+L">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Eraser" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Clear Terminal"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+T">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PlusBox" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="New Terminal Tab"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="HelpCircle" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Help"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="OnDocumentationClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F1">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="BookOpenPageVariant" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Documentation"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Lightbulb" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Tips and Tricks"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Bug" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Report Issue"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Click="OnAboutClicked" Style="{StaticResource ModernSubMenuItemStyle}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Information" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="About"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- Settings Button -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,40,0">
                    <Button x:Name="SettingsButton"
                        Background="Transparent" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Click="OnSettingsIconClicked"
                        Width="100"
                        Height="32"
                        Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" 
                                         Background="{TemplateBinding Background}" 
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Foreground="#cccccc" Margin="0,0,8,0"/>
                            <TextBlock Text="Settings" FontSize="12" Foreground="#cccccc"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,15,0,0">
                    <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="15,0,0,15">
                        EDITOR TOOLS
                    </TextBlock>
                    
                    <Border x:Name="NavCodeEditor" Style="{StaticResource NavButtonStyle}" Background="#2d2d30" MouseLeftButtonDown="NavItem_Click" Tag="CodeEditor">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CodeBraces" Width="14" Height="14" Foreground="White" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Code" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="NavSceneEditor" Style="{StaticResource NavButtonStyle}" Background="Transparent" MouseLeftButtonDown="NavItem_Click" Tag="SceneEditor">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Palette" Width="14" Height="14" Foreground="#e0e0e0" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Scene" Foreground="#e0e0e0" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="NavVisualScripting" Style="{StaticResource NavButtonStyle}" Background="Transparent" MouseLeftButtonDown="NavItem_Click" Tag="VisualScripting">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ShareVariant" Width="14" Height="14" Foreground="#e0e0e0" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Scripting" Foreground="#e0e0e0" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- EDITOR AREA -->
            <Grid Grid.Row="0" Grid.Column="1">
                <!-- CODE EDITOR -->
                <Border x:Name="CodeEditorContainer" Background="#1e1e1e" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Style="{StaticResource SectionHeaderStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="EDITOR"/>
                                </TextBlock.Inlines>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,15,0">
                                <Button x:Name="SaveButton" 
                                        Click="OnSaveClicked" 
                                        Style="{StaticResource SceneToolButton}" 
                                        ToolTip="Save File (Ctrl+S)"
                                        Width="32" Height="32">
                                    <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" />
                                </Button>
                                <Button x:Name="RunButton" 
                                        Click="OnRunClicked" 
                                        Style="{StaticResource SceneToolButton}" 
                                        ToolTip="Run Script (F5)" 
                                        Margin="8,0,0,0" 
                                        Background="#28a745"
                                        Width="32" Height="32">
                                    <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <TabControl x:Name="FileTabs"
                                    Grid.Row="1"
                                    Background="#2d2d30"
                                    BorderThickness="0"
                                    SelectionChanged="OnTabSelectionChanged">
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="{Binding Icon}" Width="14" Height="14" Margin="5,0,5,0"/>
                                        <TextBlock Text="{Binding Name}" Margin="0,0,5,0"/>
                                        <Button Width="16" Height="16" Background="Transparent" BorderThickness="0" Foreground="#888" Cursor="Hand" Click="OnCloseTabClick" Tag="{Binding}">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>

                        <Border Grid.Row="2" Background="#1e1e1e">
                            <wv2:WebView2 x:Name="CodeWebView"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- SCENE EDITOR -->
                <Grid x:Name="SceneEditorContainer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- SCENE TOOLBAR -->
                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="5">
                        <WrapPanel>
                            <Button Click="OnSaveScene" Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Save Scene"/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnLoadScene" Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Load Scene"/>
                                </StackPanel>
                            </Button>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Click="OnAddGameObject" Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Add Object"/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnSavePrefab" Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Save Prefab"/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnLoadPrefab" Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Load Prefab"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Duplicate"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Delete"/>
                                </StackPanel>
                            </Button>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Undo" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Undo"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Redo" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Redo"/>
                                </StackPanel>
                            </Button>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="MagnifyPlus" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Zoom In"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="MagnifyMinus" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Zoom Out"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Reset View"/>
                                </StackPanel>
                            </Button>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <ToggleButton x:Name="PlayToggle"
                                          Click="OnPlayToggle"
                                          Margin="2"
                                          Padding="10,5"
                                          Background="#28a745"
                                          Foreground="White"
                                          BorderThickness="0"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="{TemplateBinding Background}" 
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#34ce57"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#dc3545"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Play"/>
                                </StackPanel>
                            </ToggleButton>
                            <Button Style="{StaticResource SceneToolButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="Stop"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>

                        <!-- SCENE CANVAS -->
                        <Canvas x:Name="SceneCanvas"
                                Background="#1e1e1e"
                                AllowDrop="True"
                                Drop="OnAssetDropped"
                                Grid.Column="0"
                                ClipToBounds="True"
                                MouseLeftButtonDown="SceneCanvas_MouseDown"
                                MouseMove="SceneCanvas_MouseMove"
                                MouseLeftButtonUp="SceneCanvas_MouseUp"
                                MouseWheel="SceneCanvas_MouseWheel"/>

                        <!-- HIERARCHY & INSPECTOR PANEL -->
                        <Border x:Name="InspectorContainer" Grid.Column="1" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1,0,0,0">
                            <DockPanel>
                                <!-- Hierarchy Section -->
                                <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Foreground="#aaaaaa" FontSize="14" FontWeight="Bold" Margin="10,8,10,5">
                                            HIERARCHY
                                        </TextBlock>
                                        <TextBox x:Name="SearchHierarchy" 
                         Background="#1e1e1e" 
                         Foreground="White" 
                         BorderBrush="#3c3c3c"
                         Margin="10,0,10,8"
                         Padding="5"
                         FontSize="12">
                                            <TextBox.Tag>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,5,0"/>
                                                    <TextBlock Text="Search objects..."/>
                                                </StackPanel>
                                            </TextBox.Tag>
                                        </TextBox>
                                    </StackPanel>
                                </Border>

                                <ListBox x:Name="SceneHierarchy"
                                         Background="#1e1e1e"
                                         Foreground="White"
                                         BorderThickness="0"
                                         DisplayMemberPath="Name"
                                         Margin="0,0,0,5"
                                         SelectionChanged="OnHierarchySelectionChanged"/>

                                <!-- Inspector Section -->
                                <Border DockPanel.Dock="Bottom" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,1,0,0" Margin="0,5,0,0">
                                    <StackPanel>
                                        <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="10,8,10,5">
                                            INSPECTOR
                                        </TextBlock>
                                        <Button Style="{StaticResource SceneToolButton}" Margin="10,0,10,8" Background="#007acc">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,5,0"/>
                                                <TextBlock Text="Add Component"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="InspectorPanel" Margin="10">
                                        <!-- inspector content -->
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- VISUAL SCRIPTING -->
                <Border x:Name="VisualScriptingContainer" Background="#1e1e1e" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}">
                            <TextBlock.Inlines>
                                <Run Text="VISUAL SCRIPTING"/>
                            </TextBlock.Inlines>
                        </TextBlock>

                        <!-- Node Toolbar -->
                        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="5" Margin="0,10,0,0">
                            <WrapPanel>
                                <Button Style="{StaticResource SceneToolButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Add Node"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Delete Node"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="LinkVariant" Width="14" Height="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Connect"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Save Graph"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Load Graph"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Border>

                        <!-- Node Canvas -->
                        <Canvas x:Name="NodeCanvas" 
                                Grid.Row="1" 
                                Background="#1e1e1e" 
                                ClipToBounds="True"/>

                        <!-- Node Properties -->
                        <Border Grid.Row="2" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,1,0,0" Height="150">
                            <StackPanel Margin="10">
                                <TextBlock Foreground="#aaaaaa" FontSize="14" FontWeight="Bold" Margin="0,0,0,10">
                                    NODE PROPERTIES
                                </TextBlock>
                                <TextBlock Text="Node Name:" Foreground="#888888" FontSize="12"/>
                                <TextBox Text="New Node" Background="#1e1e1e" Foreground="White" BorderBrush="#3c3c3c" Margin="0,5,0,10" Padding="5"/>
                                <TextBlock Text="Node Type:" Foreground="#888888" FontSize="12"/>
                                <ComboBox Background="#1e1e1e" Foreground="White" BorderBrush="#3c3c3c" Margin="0,5,0,0">
                                    <ComboBoxItem>Action</ComboBoxItem>
                                    <ComboBoxItem>Condition</ComboBoxItem>
                                    <ComboBoxItem>Event</ComboBoxItem>
                                    <ComboBoxItem>Loop</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT PANEL -->
            <Grid Grid.Row="0" Grid.Column="2" Grid.RowSpan="2">
                <!-- FILE EXPLORER -->
                <Border x:Name="ExplorerContainer" 
                        Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1,0,0,0"
                        Visibility="Visible">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                            <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="10,10,10,10">
                                EXPLORER
                            </TextBlock>
                        </Border>

                        <Border DockPanel.Dock="Top" Background="#252526" Padding="5">
                            <WrapPanel>
                                <Button Click="OnNewFileToolbarClick" Style="{StaticResource SceneToolButton}" Margin="0,0,5,0">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FilePlus" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="New File"/>
                                    </StackPanel>
                                </Button>
                                <Button Click="OnNewFolderToolbarClick" Style="{StaticResource SceneToolButton}" Margin="0,0,5,0">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderPlus" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="New Folder"/>
                                    </StackPanel>
                                </Button>
                                <Button Click="OnRefreshClicked" Style="{StaticResource SceneToolButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="Refresh"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Border>

                        <TreeView x:Name="FileTree"
                                  Background="#252526"
                                  Foreground="White"
                                  BorderThickness="0"
                                  FontSize="12"
                                  AllowDrop="True"
                                  DragEnter="OnTreeViewDragEnter"
                                  Drop="OnTreeViewDrop"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewRightClick"
                                  SelectedItemChanged="OnFileTreeSelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:FileNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Tag="{Binding}">
                                        <iconPacks:PackIconMaterial Kind="{Binding IconKind}" Width="14" Height="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- OUTPUT CONSOLE -->
            <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                    Background="#1e1e1e"
                    BorderBrush="#3c3c3c"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="10,8,0,8">
                                OUTPUT
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                                <Button Click="OnClearConsoleClicked" Background="Transparent" Foreground="#aaaaaa" BorderThickness="0" FontSize="12" Cursor="Hand" Margin="5,0">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Eraser" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="Clear"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBox x:Name="OutputConsole"
                             Grid.Row="1"
                             Background="#1e1e1e"
                             Foreground="#4ec9b0"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Margin="10,5,10,10"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Notification Toast -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="3" Padding="20,12" BorderBrush="#007acc" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial x:Name="ToastIcon" Kind="CheckCircle" Width="18" Height="18" Foreground="#4ec9b0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Action completed successfully!" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Page>
