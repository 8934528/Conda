<Page x:Class="Conda.UI.Views.EditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Conda.Editor"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Conda Editor"
      Height="700"
      Width="1200"
      Background="#1e1e1e"
      MinWidth="600"
      MinHeight="400">

    <Page.Resources>
        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Header="📝 Open" Click="OnOpenFileClick"/>
            <Separator/>
            <MenuItem Header="📄 New File" Click="OnNewFileClick"/>
            <MenuItem Header="📁 New Folder" Click="OnNewFolderClick"/>
            <Separator/>
            <MenuItem Header="✏️ Rename" Click="OnRenameClick"/>
            <MenuItem Header="🗑️ Delete" Click="OnDeleteClick"/>
        </ContextMenu>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!-- TITLE BAR WITH LOGO & BUTTONS -->
        <!-- ========================= -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#2d2d30">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="../Assets/logo/FirstIcon.png" Width="28" Height="28" Margin="0,0,10,0"/>
                    <TextBlock Text="Conda Editor" FontSize="16" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button x:Name="CloseFolderBtn"
                            Content="📁 Close Folder"
                            Click="OnCloseFolderClicked"
                            Background="#3c3c3c"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"
                            Padding="10,6"
                            Margin="0,0,10,0"/>

                    <Button x:Name="InstallDepsBtn"
                            Content="📦 Install Dependencies"
                            Click="OnInstallDependenciesClicked"
                            Background="#2d5a2d"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"
                            Padding="10,6"
                            Margin="0,0,10,0"/>

                    <Button x:Name="ActivateVenvBtn"
                            Content="🐍 Activate Venv"
                            Click="OnToggleVenvClicked"
                            Background="#6a1b9a"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="12"
                            Padding="10,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========================= -->
        <!-- TOOLBAR (Buttons on right) -->
        <!-- ========================= -->
        <Border Grid.Row="1" Grid.Column="1" Background="#2d2d30" Height="40" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                <Button x:Name="SaveBtn"
                        Content="💾 Save"
                        Click="OnSaveClicked"
                        Margin="5,0"
                        Padding="12,6"
                        Background="#3c3c3c"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"/>

                <Button x:Name="RunBtn"
                        Content="▶ Run"
                        Click="OnRunClicked"
                        Margin="5,0"
                        Padding="12,6"
                        Background="#007acc"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"/>

                <Button x:Name="StopBtn"
                        Content="⛔ Stop"
                        Click="OnStopClicked"
                        Margin="5,0"
                        Padding="12,6"
                        Background="#c72c41"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- ========================= -->
        <!-- FILE EXPLORER -->
        <!-- ========================= -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Grid.Column="0"
                Background="#252526"
                BorderBrush="#3c3c3c"
                BorderThickness="0,0,1,0">

            <DockPanel>
                <TextBlock Text="📁 EXPLORER"
                           DockPanel.Dock="Top"
                           Foreground="#aaaaaa"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="10,10,10,5"/>

                <TreeView x:Name="FileTree"
                          Background="#252526"
                          Foreground="White"
                          BorderThickness="0"
                          FontSize="13"
                          AllowDrop="True"
                          DragEnter="OnTreeViewDragEnter"
                          Drop="OnTreeViewDrop"
                          PreviewMouseRightButtonDown="OnTreeViewPreviewRightClick">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type local:FileNode}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Tag="{Binding}">
                                <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

        </Border>

        <!-- ========================= -->
        <!-- TAB CONTROL FOR OPEN FILES -->
        <!-- ========================= -->
        <Border Grid.Row="1" Grid.Column="1" Background="#1e1e1e">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TabControl x:Name="FileTabs"
                            Grid.Row="0"
                            Background="#2d2d30"
                            BorderThickness="0"
                            SelectionChanged="OnTabSelectionChanged">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Margin="5,0"/>
                                <Button Content="✕" 
                                        Width="16" 
                                        Height="16" 
                                        Margin="5,0,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#888"
                                        Cursor="Hand"
                                        Click="OnCloseTabClick"
                                        Tag="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>

                <Border Grid.Row="1" Background="#1e1e1e">
                    <wv2:WebView2 x:Name="CodeWebView"/>
                </Border>
            </Grid>
        </Border>

        <!-- ========================= -->
        <!-- OUTPUT CONSOLE -->
        <!-- ========================= -->
        <Border Grid.Row="2" Grid.Column="1"
                Background="#1e1e1e"
                BorderBrush="#3c3c3c"
                BorderThickness="0,1,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📟 OUTPUT"
                           Foreground="#aaaaaa"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="10,8,0,5"/>

                <TextBox x:Name="OutputConsole"
                         Grid.Row="1"
                         Background="#1e1e1e"
                         Foreground="#4ec9b0"
                         FontFamily="Consolas"
                         FontSize="13"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Margin="10,0,10,10"/>
            </Grid>
        </Border>

    </Grid>

</Page>
