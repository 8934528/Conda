<Page x:Class="Conda.UI.Views.EditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:views="clr-namespace:Conda.UI.Views"
      xmlns:local="clr-namespace:Conda.Editor"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1400"
      Background="#1e1e1e"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="50" To="0" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Header="Open" Click="OnOpenFileClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="New File" Click="OnNewFileClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FilePlus" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="New Folder" Click="OnNewFolderClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Rename" Click="OnRenameClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Delete" Click="OnDeleteClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Copy Path" Click="OnCopyPathClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Reveal in Explorer" Click="OnRevealInExplorerClick">
                <MenuItem.Icon>
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10,10,10,5"/>
        </Style>

        <Style x:Key="SceneToolButton" TargetType="Button">
            <Setter Property="Background" Value="#3c3c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4c4c4c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Border">
            <Setter Property="Margin" Value="10,2,10,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3e3e42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Control -->
        <views:TitleBarControl Grid.Row="0" 
                               NewProjectClicked="OnNewProjectClicked"
                               OpenProjectClicked="OnOpenProjectClicked"
                               ExitClicked="OnExitClicked"
                               PreferencesClicked="OnPreferencesClicked"
                               SettingsClicked="OnSettingsClicked"
                               ToggleFullScreenClicked="OnToggleFullScreenClicked"
                               ResetLayoutClicked="OnResetLayoutClicked"
                               RecentProjectsClicked="OnRecentProjectsClicked"
                               ProjectSettingsClicked="OnProjectSettingsClicked"
                               BuildClicked="OnBuildClicked"
                               ExportClicked="OnExportClicked"
                               PackageManagerClicked="OnPackageManagerClicked"
                               ExtensionsClicked="OnExtensionsClicked"
                               OpenTerminalClicked="OnOpenTerminalClicked"
                               RunCommandClicked="OnRunCommandClicked"
                               DocumentationClicked="OnDocumentationClicked"
                               AboutClicked="OnAboutClicked"
                               SettingsIconClicked="OnSettingsIconClicked"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/> <!-- Left Sidebar -->
                <ColumnDefinition Width="5"/> <!-- Splitter -->
                <ColumnDefinition Width="*"/> <!-- Center Area -->
                <ColumnDefinition Width="5"/> <!-- Splitter -->
                <ColumnDefinition Width="280" MinWidth="200"/> <!-- Right Sidebar -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/> <!-- Top Area -->
                <RowDefinition Height="5"/> <!-- Splitter -->
                <RowDefinition Height="250" MinHeight="100"/> <!-- Bottom Panel -->
            </Grid.RowDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,15,0,0">
                    <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="15,0,0,15" VerticalAlignment="Center">
                        EDITOR TOOLS
                    </TextBlock>
                    
                    <Border x:Name="NavCodeEditor" Style="{StaticResource NavButtonStyle}" Background="#2d2d30" MouseLeftButtonDown="NavItem_Click" Tag="CodeEditor">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="CodeBraces" Width="14" Height="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Code" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="NavSceneEditor" Style="{StaticResource NavButtonStyle}" Background="Transparent" MouseLeftButtonDown="NavItem_Click" Tag="SceneEditor">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Palette" Width="14" Height="14" Foreground="#e0e0e0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Scene" Foreground="#e0e0e0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="NavVisualScripting" Style="{StaticResource NavButtonStyle}" Background="Transparent" MouseLeftButtonDown="NavItem_Click" Tag="VisualScripting">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="ShareVariant" Width="14" Height="14" Foreground="#e0e0e0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Scripting" Foreground="#e0e0e0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="NavAddVenv" 
                            Style="{StaticResource NavButtonStyle}" 
                            Background="Transparent" 
                            MouseLeftButtonDown="OnAddVenvClicked" 
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="LanguagePython" Width="14" Height="14" Foreground="#ff8c00" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Venv" Foreground="#ff8c00" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- LEFT SPLITTER -->
            <GridSplitter Grid.Column="1" Grid.RowSpan="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- EDITOR AREA -->
            <Grid Grid.Row="0" Grid.Column="2">
                <!-- CODE EDITOR -->
                <Border x:Name="CodeEditorContainer" Background="#1e1e1e" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center">
                                <TextBlock.Inlines>
                                    <Run Text="EDITOR"/>
                                </TextBlock.Inlines>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,15,0">
                                <Button x:Name="SaveButton" 
                                        Click="OnSaveClicked" 
                                        Style="{StaticResource SceneToolButton}" 
                                        ToolTip="Save File (Ctrl+S)"
                                        Width="32" Height="32">
                                    <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="RunButton" 
                                        Click="OnRunClicked" 
                                        Style="{StaticResource SceneToolButton}" 
                                        ToolTip="Run Script (F5)" 
                                        Margin="8,0,0,0" 
                                        Background="#28a745"
                                        Width="32" Height="32">
                                    <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <TabControl x:Name="FileTabs"
                                    Grid.Row="1"
                                    Background="#2d2d30"
                                    BorderThickness="0"
                                    FontSize="12"
                                    SelectionChanged="OnTabSelectionChanged">
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="{Binding Icon}" Width="14" Height="14" Margin="5,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <Button Width="16" Height="16" Background="Transparent" BorderThickness="0" Foreground="#888" Cursor="Hand" Click="OnCloseTabClick" Tag="{Binding}" VerticalAlignment="Center">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>

                        <Border Grid.Row="2" Background="#1e1e1e">
                            <wv2:WebView2 x:Name="CodeWebView"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- SCENE EDITOR -->
                <Grid x:Name="SceneEditorContainer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- SCENE TOOLBAR -->
                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="5">
                        <WrapPanel VerticalAlignment="Center">
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Undo" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="Undo" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Redo" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="Redo" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>

                            
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Click="OnSaveScene" Style="{StaticResource SceneToolButton}" ToolTip="Save Scene" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Click="OnLoadScene" Style="{StaticResource SceneToolButton}" ToolTip="Load Scene" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Click="OnAddGameObject" Style="{StaticResource SceneToolButton}" ToolTip="Add Object" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Click="OnSavePrefab" Style="{StaticResource SceneToolButton}" ToolTip="Save Prefab" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="ContentSaveOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Click="OnLoadPrefab" Style="{StaticResource SceneToolButton}" ToolTip="Load Prefab" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Duplicate" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Delete" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>




                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Zoom In" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="MagnifyPlus" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Zoom Out" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="MagnifyMinus" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Reset View" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <ToggleButton x:Name="PlayToggle"
                                          Click="OnPlayToggle"
                                          Margin="4,4,16,0"
                                          Padding="10,5"
                                          Background="#28a745"
                                          Foreground="White"
                                          BorderThickness="0"
                                          ToolTip="Play/Stop Simulation"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="{TemplateBinding Background}" 
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#34ce57"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#dc3545"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <iconPacks:PackIconMaterial Kind="Play" Width="14" Height="14" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Button Style="{StaticResource SceneToolButton}" ToolTip="Stop Simulation" Margin="4,4,16,0">
                                <iconPacks:PackIconMaterial Kind="Stop" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Button>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="250" MinWidth="150"/>
                        </Grid.ColumnDefinitions>

                        <!-- SCENE CANVAS -->
                        <Canvas x:Name="SceneCanvas"
                                Background="#1e1e1e"
                                AllowDrop="True"
                                Drop="OnAssetDropped"
                                Grid.Column="0"
                                ClipToBounds="True"
                                MouseLeftButtonDown="SceneCanvas_MouseDown"
                                MouseMove="SceneCanvas_MouseMove"
                                MouseLeftButtonUp="SceneCanvas_MouseUp"
                                MouseWheel="SceneCanvas_MouseWheel"/>

                        <!-- CENTER SPLITTER -->
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

                        <!-- HIERARCHY & INSPECTOR PANEL -->
                        <Border x:Name="InspectorContainer" Grid.Column="2" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1,0,0,0">
                            <DockPanel>
                                <!-- Hierarchy Section -->
                                <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="10,8,10,5" VerticalAlignment="Center">
                                            HIERARCHY
                                        </TextBlock>
                                        <TextBox x:Name="SearchHierarchy" 
                                                 Background="#1e1e1e" 
                                                 Foreground="White" 
                                                 BorderBrush="#3c3c3c"
                                                 Margin="10,0,10,8"
                                                 Padding="5"
                                                 FontSize="12"
                                                 VerticalAlignment="Center">
                                            <TextBox.Tag>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Search objects..." VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </TextBox.Tag>
                                        </TextBox>
                                    </StackPanel>
                                </Border>

                                <ListBox x:Name="SceneHierarchy"
                                         Background="#1e1e1e"
                                         Foreground="White"
                                         BorderThickness="0"
                                         DisplayMemberPath="Name"
                                         FontSize="12"
                                         Margin="0,0,0,5"
                                         SelectionChanged="OnHierarchySelectionChanged"/>

                                <!-- Inspector Section -->
                                <Border DockPanel.Dock="Bottom" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,1,0,0" Margin="0,5,0,0">
                                    <StackPanel>
                                        <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="10,8,10,5" VerticalAlignment="Center">
                                            INSPECTOR
                                        </TextBlock>
                                        <Button Style="{StaticResource SceneToolButton}" Margin="10,0,10,8" Background="#ff8c00" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Add Component" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="InspectorPanel" Margin="10">
                                        <!-- inspector content -->
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- VISUAL SCRIPTING -->
                <Border x:Name="VisualScriptingContainer" Background="#1e1e1e" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="150" MinHeight="100"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center">
                            <TextBlock.Inlines>
                                <Run Text="VISUAL SCRIPTING"/>
                            </TextBlock.Inlines>
                        </TextBlock>

                        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="5" Margin="0,10,0,0">
                            <WrapPanel VerticalAlignment="Center">
                                <Button Style="{StaticResource SceneToolButton}" ToolTip="Add Node" Margin="4,4,16,0">
                                    <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}" ToolTip="Delete Node" Margin="4,4,16,0">
                                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}" ToolTip="Connect" Margin="4,4,16,0">
                                    <iconPacks:PackIconMaterial Kind="LinkVariant" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}" ToolTip="Save Graph" Margin="4,4,16,0">
                                    <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SceneToolButton}" ToolTip="Load Graph" Margin="4,4,16,0">
                                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                            </WrapPanel>
                        </Border>

                        <!-- Node Canvas -->
                        <Canvas x:Name="NodeCanvas" 
                                Grid.Row="1" 
                                Background="#1e1e1e" 
                                ClipToBounds="True"/>

                        <!-- SCRIPTING SPLITTER -->
                        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

                        <!-- Node Properties -->
                        <Border Grid.Row="3" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,1,0,0">
                            <StackPanel Margin="10">
                                <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="0,0,0,10" VerticalAlignment="Center">
                                    NODE PROPERTIES
                                </TextBlock>
                                <TextBlock Text="Node Name:" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Text="New Node" Background="#1e1e1e" Foreground="White" BorderBrush="#3c3c3c" Margin="0,5,0,10" Padding="5" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="Node Type:" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox Background="#1e1e1e" Foreground="White" BorderBrush="#3c3c3c" Margin="0,5,0,0" FontSize="12" VerticalAlignment="Center">
                                    <ComboBoxItem Background="#2d2d30" Foreground="White">Action</ComboBoxItem>
                                    <ComboBoxItem Background="#2d2d30" Foreground="White">Condition</ComboBoxItem>
                                    <ComboBoxItem Background="#2d2d30" Foreground="White">Event</ComboBoxItem>
                                    <ComboBoxItem Background="#2d2d30" Foreground="White">Loop</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT SPLITTER -->
            <GridSplitter Grid.Column="3" Grid.RowSpan="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- RIGHT PANEL (EXPLORER) -->
            <Grid Grid.Row="0" Grid.Column="4" Grid.RowSpan="3">
                <Border x:Name="ExplorerContainer" 
                        Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1,0,0,0"
                        Visibility="Visible">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                            <TextBlock Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" Margin="10,10,10,10" VerticalAlignment="Center">
                                EXPLORER
                            </TextBlock>
                        </Border>

                        <Border DockPanel.Dock="Top" Background="#252526" Padding="5">
                            <WrapPanel VerticalAlignment="Center">
                                <Button Click="OnNewFileToolbarClick" Style="{StaticResource SceneToolButton}" Margin="4,4,16,0" ToolTip="New File">
                                    <iconPacks:PackIconMaterial Kind="FilePlus" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                                <Button Click="OnNewFolderToolbarClick" Style="{StaticResource SceneToolButton}" Margin="4,4,16,0" ToolTip="New Folder">
                                    <iconPacks:PackIconMaterial Kind="FolderPlus" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                                <Button Click="OnRefreshClicked" Style="{StaticResource SceneToolButton}" Margin="4,4,16,0" ToolTip="Refresh">
                                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Button>
                            </WrapPanel>
                        </Border>

                        <TreeView x:Name="FileTree"
                                  Background="#252526"
                                  Foreground="White"
                                  BorderThickness="0"
                                  FontSize="12"
                                  Margin="4,4,0,0"
                                  AllowDrop="True"
                                  DragEnter="OnTreeViewDragEnter"
                                  Drop="OnTreeViewDrop"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewRightClick"
                                  SelectedItemChanged="OnFileTreeSelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:FileNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Tag="{Binding}" VerticalAlignment="Center">
                                        <iconPacks:PackIconMaterial x:Name="NodeIcon" Kind="{Binding IconKind}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                    <HierarchicalDataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter TargetName="NodeIcon" Property="Kind" Value="FolderOpen"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                                            <Setter TargetName="NodeIcon" Property="Kind" Value="{Binding IconKind}"/>
                                        </DataTrigger>
                                    </HierarchicalDataTemplate.Triggers>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- BOTTOM SPLITTER -->
            <GridSplitter Grid.Row="1" Grid.Column="2" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- BOTTOM PANEL (OUTPUT & TERMINAL) -->
            <Border Grid.Row="2" Grid.Column="2" 
                    Background="#1e1e1e"
                    BorderBrush="#3c3c3c"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TAB HEADERS & TOOLBAR -->
                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="TabOutputBtn" Click="OnTabOutputClick" Background="#2d2d30" Foreground="White" BorderThickness="0,0,0,2" BorderBrush="#ff8c00" Padding="15,8" FontSize="12" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center">
                                    OUTPUT
                                </Button>
                                <Button x:Name="TabTerminalBtn" Click="OnTabTerminalClick" Background="Transparent" Foreground="#aaaaaa" BorderThickness="0" Padding="15,8" FontSize="12" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center">
                                    TERMINAL
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Button x:Name="InstallReqButton" 
                                        Click="OnInstallRequirementsClicked" 
                                        Background="#ff8c00" 
                                        Foreground="White" 
                                        BorderThickness="0" 
                                        FontSize="11" 
                                        Padding="8,4" 
                                        Margin="0,0,10,0" 
                                        Visibility="Collapsed"
                                        Cursor="Hand"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="Download" Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Install requirements.txt" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Click="OnClearConsoleClicked" Background="Transparent" Foreground="#aaaaaa" BorderThickness="0" FontSize="12" Cursor="Hand" Margin="5,0" VerticalAlignment="Center" ToolTip="Clear Console">
                                    <iconPacks:PackIconMaterial Kind="Eraser" Width="12" Height="12" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- TAB CONTENT -->
                    <Grid Grid.Row="1">
                        <!-- OUTPUT TAB CONTENT -->
                        <TextBox x:Name="OutputConsole"
                                 Visibility="Visible"
                                 Background="#1e1e1e"
                                 Foreground="#4ec9b0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Margin="10,5,10,10"/>

                        <!-- TERMINAL TAB CONTENT -->
                        <Grid x:Name="TerminalContainer" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBox x:Name="TerminalConsole"
                                     Grid.Row="0"
                                     Background="#1e1e1e"
                                     Foreground="#cccccc"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Margin="10,5,10,5"/>

                            <Grid Grid.Row="1" Margin="10,0,10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="$ " Foreground="#ff8c00" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12"/>
                                <TextBox x:Name="TerminalInput"
                                         Grid.Column="1"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         CaretBrush="White"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         VerticalAlignment="Center"
                                         KeyDown="TerminalInput_KeyDown"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Notification Toast -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="3" Padding="20,12" BorderBrush="#ff8c00" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial x:Name="ToastIcon" Kind="CheckCircle" Width="18" Height="18" Foreground="#4ec9b0" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Action completed successfully!" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Page>
