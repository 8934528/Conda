<Page x:Class="Conda.UI.Views.EditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Conda.Editor"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1400"
      Title="Conda Editor"
      Background="#1e1e1e"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Animations -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="50" To="0" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>

        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Header="📝 Open" Click="OnOpenFileClick"/>
            <Separator/>
            <MenuItem Header="📄 New File" Click="OnNewFileClick"/>
            <MenuItem Header="📁 New Folder" Click="OnNewFolderClick"/>
            <Separator/>
            <MenuItem Header="✏️ Rename" Click="OnRenameClick"/>
            <MenuItem Header="🗑️ Delete" Click="OnDeleteClick"/>
            <Separator/>
            <MenuItem Header="📋 Copy Path" Click="OnCopyPathClick"/>
            <MenuItem Header="🔄 Reveal in Explorer" Click="OnRevealInExplorerClick"/>
        </ContextMenu>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10,10,10,5"/>
        </Style>

        <Style x:Key="SceneToolButton" TargetType="Button">
            <Setter Property="Background" Value="#3c3c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4c4c4c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Navs & Tabs -->
        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.Resources>
                    <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#cccccc"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Margin="2,0">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                                <Border x:Name="SubmenuBorder" 
                                        Background="#252526" 
                                        BorderBrush="#3c3c3c" 
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        Padding="4">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="15" 
                                                          Opacity="0.3" 
                                                          ShadowDepth="2"
                                                          Color="Black"/>
                                                    </Border.Effect>
                                                    <StackPanel IsItemsHost="True" 
                                                KeyboardNavigation.DirectionalNavigation="Cycle"
                                                Margin="0,4"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSubmenuOpen" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSubMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#e0e0e0"/>
                        <Setter Property="Padding" Value="12,8,12,8"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="4"
                            Margin="2">
                                        <Grid>
                                            <ContentPresenter x:Name="HeaderHost" 
                                              ContentSource="Header" 
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2d2d30"/>
                                            <Setter Property="Foreground" Value="#007acc"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style x:Key="ModernSeparatorStyle" TargetType="Separator">
                        <Setter Property="Background" Value="#3c3c3c"/>
                        <Setter Property="Height" Value="1"/>
                        <Setter Property="Margin" Value="8,4,8,4"/>
                    </Style>
                </Grid.Resources>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="/Assets/logo/FirstIcon.png" Width="28" Height="28" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="450,0,0,0">
                    <Menu Background="Transparent" BorderThickness="0">
                        <MenuItem Header="File" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="📁 New Project" Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+N"/>
                            <MenuItem Header="📂 Open Project" Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+O"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="💾 Save All" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+S"/>
                            <MenuItem Header="🔄 Recent Projects" Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="❌ Exit" Click="OnExitClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Alt+F4"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="Edit" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="✂️ Cut" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+X"/>
                            <MenuItem Header="📋 Copy" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+C"/>
                            <MenuItem Header="📌 Paste" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+V"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="⚙️ Preferences" Click="OnPreferencesClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+,"/>
                            <MenuItem Header="🔧 Settings" Click="OnSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+,"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="View" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🖥️ Toggle Full Screen" Click="OnToggleFullScreenClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F11"/>
                            <MenuItem Header="🔄 Reset Layout" Click="OnResetLayoutClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="📊 Show Dashboard" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+1"/>
                            <MenuItem Header="📝 Show Editor" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+2"/>
                            <MenuItem Header="📟 Show Terminal" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+`"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="Project" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🆕 New Project" Click="OnNewProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="📂 Open Project" Click="OnOpenProjectClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🕒 Recent Projects" Click="OnRecentProjectsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="⚙️ Project Settings" Click="OnProjectSettingsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="📦 Project Dependencies" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="Build" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🔨 Build Project" Click="OnBuildClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F7"/>
                            <MenuItem Header="▶️ Run Project" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F5"/>
                            <MenuItem Header="🐛 Debug Project" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F6"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="📦 Export Game" Click="OnExportClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="📋 Build Settings" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="Tools" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="📦 Package Manager" Click="OnPackageManagerClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🧩 Extensions" Click="OnExtensionsClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="🐍 Python Environment" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🔍 Code Analysis" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="Terminal" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="🖥️ Open Terminal" Click="OnOpenTerminalClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+`"/>
                            <MenuItem Header="⚡ Run Command" Click="OnRunCommandClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+P"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="🧹 Clear Terminal" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+L"/>
                            <MenuItem Header="📋 New Terminal Tab" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="Ctrl+Shift+T"/>
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Margin="5,0,0,0">
                        <MenuItem Header="Help" Style="{StaticResource ModernMenuItemStyle}">
                            <MenuItem Header="📚 Documentation" Click="OnDocumentationClicked" Style="{StaticResource ModernSubMenuItemStyle}" InputGestureText="F1"/>
                            <MenuItem Header="💡 Tips and Tricks" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <MenuItem Header="🐛 Report Issue" Style="{StaticResource ModernSubMenuItemStyle}"/>
                            <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                            <MenuItem Header="ℹ️ About" Click="OnAboutClicked" Style="{StaticResource ModernSubMenuItemStyle}"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- Settings Button with animation -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button x:Name="SettingsButton"
            Background="Transparent" 
            BorderThickness="0" 
            Cursor="Hand"
            Click="OnSettingsIconClicked"
            Width="32"
            Height="32"
            Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3c3c3c"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="⚙️" FontSize="18" Foreground="#cccccc"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="#333333" BorderBrush="#3c3c3c" BorderThickness="0,0,1,0">
                <StackPanel>
                    <Button x:Name="CodeEditorToggle" ToolTip="Code Editor" Click="OnShowCodeEditor" Height="50" Background="#1e1e1e" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="💻" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="SceneEditorToggle" ToolTip="Scene Editor" Click="OnShowSceneEditor" Height="50" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="🎨" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="VisualScriptingToggle" ToolTip="Visual Scripting" Click="OnShowVisualScripting" Height="50" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="🧠" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- EDITOR AREA -->
            <Grid Grid.Row="0" Grid.Column="1">
                <!-- CODE EDITOR -->
                <Border x:Name="CodeEditorContainer" Background="#1e1e1e" Visibility="Visible">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📝 EDITOR" Style="{StaticResource SectionHeaderStyle}"/>

                        <TabControl x:Name="FileTabs"
                                    Grid.Row="1"
                                    Background="#2d2d30"
                                    BorderThickness="0"
                                    SelectionChanged="OnTabSelectionChanged">
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="5,0,5,0" FontSize="12"/>
                                        <TextBlock Text="{Binding Name}" Margin="0,0,5,0"/>
                                        <Button Content="✕" Width="16" Height="16" Background="Transparent" BorderThickness="0" Foreground="#888" Cursor="Hand" Click="OnCloseTabClick" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>

                        <Border Grid.Row="2" Background="#1e1e1e">
                            <wv2:WebView2 x:Name="CodeWebView"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- SCENE EDITOR - Enhanced with more controls -->
                <Grid x:Name="SceneEditorContainer" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- SCENE TOOLBAR - Enhanced -->
                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="5">
                        <WrapPanel>
                            <Button Content="💾 Save Scene" Click="OnSaveScene" Style="{StaticResource SceneToolButton}"/>
                            <Button Content="📂 Load Scene" Click="OnLoadScene" Style="{StaticResource SceneToolButton}"/>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Content="➕ Add Object" Click="OnAddGameObject" Style="{StaticResource SceneToolButton}"/>
                            <Button Content="📋 Duplicate" Style="{StaticResource SceneToolButton}"/>
                            <Button Content="🗑️ Delete" Style="{StaticResource SceneToolButton}"/>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Content="⬅️ Undo" Style="{StaticResource SceneToolButton}"/>
                            <Button Content="➡️ Redo" Style="{StaticResource SceneToolButton}"/>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <Button Content="🔍 Zoom In" Style="{StaticResource SceneToolButton}"/>
                            <Button Content="🔍 Zoom Out" Style="{StaticResource SceneToolButton}"/>
                            <Button Content="🔄 Reset View" Style="{StaticResource SceneToolButton}"/>
                            <Separator Width="10" Visibility="Collapsed"/>
                            <ToggleButton x:Name="PlayToggle"
                                          Content="▶ Play"
                                          Click="OnPlayToggle"
                                          Margin="2"
                                          Padding="10,5"
                                          Background="#28a745"
                                          Foreground="White"
                                          BorderThickness="0"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="{TemplateBinding Background}" 
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#34ce57"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#dc3545"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Button Content="⏹️ Stop" Style="{StaticResource SceneToolButton}"/>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>

                        <!-- SCENE CANVAS -->
                        <Canvas x:Name="SceneCanvas"
                                Background="#1e1e1e"
                                AllowDrop="True"
                                Drop="OnSceneDrop"
                                Grid.Column="0"
                                ClipToBounds="True"/>

                        <!-- HIERARCHY & INSPECTOR PANEL -->
                        <Border Grid.Column="1" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1,0,0,0">
                            <DockPanel>
                                <!-- Hierarchy Section -->
                                <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="📋 HIERARCHY" Foreground="#aaaaaa" FontSize="11" FontWeight="Bold" Margin="10,8,10,5"/>
                                        <TextBox x:Name="SearchHierarchy" 
                         Background="#1e1e1e" 
                         Foreground="White" 
                         BorderBrush="#3c3c3c"
                         Margin="10,0,10,8"
                         Padding="5"
                         FontSize="11"
                         Tag="🔍 Search objects..."/>
                                    </StackPanel>
                                </Border>

                                <ListBox x:Name="SceneHierarchy"
                 Background="#1e1e1e"
                 Foreground="White"
                 BorderThickness="0"
                 DisplayMemberPath="Name"
                 Margin="0,0,0,5"/>

                                <!-- Inspector Section -->
                                <Border DockPanel.Dock="Bottom" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,1,0,0" Margin="0,5,0,0">
                                    <StackPanel>
                                        <TextBlock Text="🔍 INSPECTOR" Foreground="#aaaaaa" FontSize="11" FontWeight="Bold" Margin="10,8,10,5"/>
                                        <Button Content="➕ Add Component" Style="{StaticResource SceneToolButton}" Margin="10,0,10,8" Background="#007acc"/>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="SceneInspectorPanel" Margin="10">
                                        <!-- inspector content -->
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- VISUAL SCRIPTING -->
                <Border x:Name="VisualScriptingContainer" Background="#1e1e1e" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🧠 VISUAL SCRIPTING" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Node Toolbar -->
                        <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="5" Margin="0,10,0,0">
                            <WrapPanel>
                                <Button Content="➕ Add Node" Style="{StaticResource SceneToolButton}"/>
                                <Button Content="🗑️ Delete Node" Style="{StaticResource SceneToolButton}"/>
                                <Button Content="🔗 Connect" Style="{StaticResource SceneToolButton}"/>
                                <Button Content="💾 Save Graph" Style="{StaticResource SceneToolButton}"/>
                                <Button Content="📂 Load Graph" Style="{StaticResource SceneToolButton}"/>
                            </WrapPanel>
                        </Border>

                        <!-- Node Canvas -->
                        <Canvas x:Name="NodeCanvas" 
                                Grid.Row="1" 
                                Background="#1e1e1e" 
                                ClipToBounds="True"/>

                        <!-- Node Properties -->
                        <Border Grid.Row="2" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="0,1,0,0" Height="150">
                            <StackPanel Margin="10">
                                <TextBlock Text="📋 NODE PROPERTIES" Foreground="#aaaaaa" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Node Name:" Foreground="#888888" FontSize="11"/>
                                <TextBox Text="New Node" Background="#1e1e1e" Foreground="White" BorderBrush="#3c3c3c" Margin="0,5,0,10" Padding="5"/>
                                <TextBlock Text="Node Type:" Foreground="#888888" FontSize="11"/>
                                <ComboBox Background="#1e1e1e" Foreground="White" BorderBrush="#3c3c3c" Margin="0,5,0,0">
                                    <ComboBoxItem>Action</ComboBoxItem>
                                    <ComboBoxItem>Condition</ComboBoxItem>
                                    <ComboBoxItem>Event</ComboBoxItem>
                                    <ComboBoxItem>Loop</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT PANEL -->
            <Grid Grid.Row="0" Grid.Column="2" Grid.RowSpan="2">
                <!-- FILE EXPLORER -->
                <Border x:Name="ExplorerContainer" 
                        Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1,0,0,0"
                        Visibility="Visible">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                            <TextBlock Text="📁 EXPLORER" Foreground="#aaaaaa" FontSize="11" FontWeight="Bold" Margin="10,10,10,10"/>
                        </Border>

                        <Border DockPanel.Dock="Top" Background="#252526" Padding="5">
                            <WrapPanel>
                                <Button Content="📄 New File" Click="OnNewFileToolbarClick" Style="{StaticResource SceneToolButton}" Margin="0,0,5,0"/>
                                <Button Content="📁 New Folder" Click="OnNewFolderToolbarClick" Style="{StaticResource SceneToolButton}" Margin="0,0,5,0"/>
                                <Button Content="🔄 Refresh" Click="OnRefreshClicked" Style="{StaticResource SceneToolButton}"/>
                            </WrapPanel>
                        </Border>

                        <TreeView x:Name="FileTree"
                                  Background="#252526"
                                  Foreground="White"
                                  BorderThickness="0"
                                  FontSize="13"
                                  AllowDrop="True"
                                  DragEnter="OnTreeViewDragEnter"
                                  Drop="OnTreeViewDrop"
                                  PreviewMouseRightButtonDown="OnTreeViewPreviewRightClick"
                                  SelectedItemChanged="OnFileTreeSelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:FileNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Tag="{Binding}">
                                        <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- INSPECTOR PANEL -->
                <Border x:Name="InspectorContainer" 
                        Background="#252526"
                        BorderBrush="#3c3c3c"
                        BorderThickness="1,0,0,0"
                        Visibility="Collapsed">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="🔍 INSPECTOR" Foreground="#aaaaaa" FontSize="11" FontWeight="Bold" Margin="10,10,10,5"/>
                                <Button Content="➕ Add Component" Click="OnAddGameObject" Margin="10,0,10,8" Background="#007acc" Foreground="White" BorderThickness="0" Padding="8,4" FontSize="11" Cursor="Hand"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="InspectorPanel" Margin="10"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- OUTPUT CONSOLE -->
            <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                    Background="#1e1e1e"
                    BorderBrush="#3c3c3c"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2d2d30" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="📟 OUTPUT" Foreground="#aaaaaa" FontSize="11" FontWeight="Bold" Margin="10,8,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                                <Button Content="Clear" Click="OnClearConsoleClicked" Background="Transparent" Foreground="#aaaaaa" BorderThickness="0" FontSize="11" Cursor="Hand" Margin="5,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBox x:Name="OutputConsole"
                             Grid.Row="1"
                             Background="#1e1e1e"
                             Foreground="#4ec9b0"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Margin="10,5,10,10"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Notification Toast -->
        <Grid x:Name="ToastOverlay" Grid.RowSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,50" Visibility="Collapsed">
            <Border Background="#333333" CornerRadius="3" Padding="20,12" BorderBrush="#007acc" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastIcon" Text="✅" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ToastMessage" Text="Action completed successfully!" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="100"/>
            </Grid.RenderTransform>
        </Grid>
    </Grid>
</Page>
    